# 复制为 .env 后填写真实值；.env 勿提交到 Git
# cp .env.example .env   (Windows: copy .env.example .env)

# Django
SECRET_KEY=请生成随机长字符串-不要在版本库中保留真实值
DEBUG=False
# 多个主机用英文逗号分隔
ALLOWED_HOSTS=127.0.0.1,localhost

# MySQL
DB_NAME=oa_db
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# 邮件（QQ 邮箱示例：使用 SMTP 授权码，非 QQ 密码）
EMAIL_USE_TLS=True
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Celery / Redis
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
CACHE_URL=redis://127.0.0.1:6379/3
