# 复制为 .env 后按环境填写
# Windows: copy .env.example .env
# Linux/macOS: cp .env.example .env

# Django
SECRET_KEY=请自行生成随机长字符串
DEBUG=False
# 多个主机用英文逗号分隔（含本机与线上 IP/域名）
ALLOWED_HOSTS=127.0.0.1,localhost

# MySQL
DB_NAME=oa_db
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# 邮件（示例为 QQ 邮箱，使用 SMTP 授权码）
EMAIL_USE_TLS=True
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Celery / Redis
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
CACHE_URL=redis://127.0.0.1:6379/3

# 可选；不写则使用项目下 logs/oa.log。Linux 部署示例: /data/log/oa.log
# LOG_FILE=

# 日志级别：同时作用于控制台与 logs/oa.log。默认 INFO；排错时可设 DEBUG
# DJANGO_LOG_LEVEL=INFO
